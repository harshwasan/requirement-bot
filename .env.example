# ── INPUT SOURCE ──────────────────────────────────────────
# Which platform(s) to listen on: whatsapp | telegram | both
INPUT_SOURCE=telegram

# WhatsApp — comma-separated group JIDs from groups you administer/are allowed to monitor
WA_ALLOWED_GROUPS=WA_GROUP_JID_1,WA_GROUP_JID_2
# Human-readable names for each JID (used in output messages)
# Format: JID=Name pairs, comma-separated
WA_GROUP_NAMES=WA_GROUP_JID_1=Demo Cars Group,WA_GROUP_JID_2=Demo Property Group

# Telegram — comma-separated group chat IDs (negative numbers for groups)
TG_ALLOWED_GROUPS=TG_GROUP_ID_1,TG_GROUP_ID_2
TG_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN

# ── OUTPUT TARGETS ────────────────────────────────────────
# Where to send results: telegram | whatsapp | both
OUTPUT_TARGET=telegram

# WhatsApp — comma-separated JIDs to send results to (can be self, group, or user)
WA_OUTPUT_TARGETS=WA_OUTPUT_JID_1

# Telegram — comma-separated chat IDs to send results to
TG_OUTPUT_TARGETS=TG_OUTPUT_CHAT_ID_1,TG_OUTPUT_CHAT_ID_2

# ── AI PROVIDER ───────────────────────────────────────────
# Which AI to use: claude | claude-cli | codex | ollama
#   claude     -> Anthropic API (needs ANTHROPIC_API_KEY + AI_MODEL)
#   claude-cli -> local Claude Code CLI (uses an installed Claude subscription)
#   codex      -> OpenAI (needs OPENAI_API_KEY)
#   ollama     -> local open-source models (fully offline)
AI_PROVIDER=claude
# Model name for the selected provider.
# Default is the most capable; for high-volume/cost-sensitive use try
# claude-sonnet-4-6 (balanced) or claude-haiku-4-5 (cheapest).
AI_MODEL=claude-opus-4-8

# Anthropic (Claude)
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# OpenAI (Codex / GPT)
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# Ollama (local open source)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── DOMAIN CONFIGURATION ──────────────────────────────────
# Domain preset: used_cars | real_estate | custom
DOMAIN=used_cars
# Description used in AI prompts (override for custom domain)
DOMAIN_DESCRIPTION=used cars and vehicles

# Comma-separated list of websites the agent is ALLOWED to search.
# The agent can ONLY search/scrape these hostnames — nothing else.
SEARCH_SITES=carwale.com,cardekho.com,cars24.com,spinny.com,olx.in

# Preferred location for search results (free text, used in agent prompts)
LOCATION=Demo City

# How results should be ranked (free text, used in agent instructions)
SEARCH_PRIORITY=quality and condition first, then proximity, then price

# ── SESSION & CONTROL ─────────────────────────────────────
# Hour (0-23) at which to reset the daily session (0 = midnight)
DAILY_RESET_HOUR=0
# How many requirements to process at the same time (1 = sequential)
MAX_CONCURRENT_AGENTS=1
# Requirement result reply format: combined | per_match
REQUIREMENT_REPLY_MODE=combined
# Local callback API port used by interactive Claude subagents
CLAUDE_CALLBACK_PORT=8787
# Keep false for public/demo use. Set true only in a private, trusted sandbox if you understand the risk.
REQBOT_ALLOW_CLAUDE_BYPASS=false

# ── STORAGE ───────────────────────────────────────────────
# Path to SQLite database file
DB_PATH=./data/requirement-bot.db
# Path to store downloaded images from listings
IMAGES_DIR=./data/images

# ── LOGGING ───────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
# Pretty-print logs (set to false in production)
LOG_PRETTY=true
